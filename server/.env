# ================================================
# FitChain Server — Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas > Cluster > Connect > Connect your application
MONGODB_URI=mongodb+srv://fitchainv2:Ritik%401100@cluster0.8jwtep8.mongodb.net/fitchain?retryWrites=true&w=majority

# JWT Secret — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry duration
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Client origin for CORS (your frontend dev URL)
CLIENT_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
